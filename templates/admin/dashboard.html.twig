{% extends 'base.html.twig' %}
{% block title %}Admin Dashboard{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>⚙️ Admin Dashboard</h1>
  <a href="{{ path('app_admin_recipe_new') }}" class="btn btn-warning">+ New Recipe</a>
</div>

{% if recipes is empty %}
  <div class="alert alert-info">No recipes yet. Create your first one!</div>
{% else %}
<div class="table-responsive">
  <table class="table table-hover align-middle">
    <thead class="table-dark">
      <tr>
        <th>Title</th><th>Cuisine</th><th>Meal Type</th><th>Difficulty</th><th>Date</th><th>Actions</th>
      </tr>
    </thead>
    <tbody>
      {% for recipe in recipes %}
      <tr>
        <td><strong>{{ recipe.title }}</strong></td>
        <td>{{ recipe.cuisine.name }}</td>
        <td><span class="badge bg-warning text-dark">{{ recipe.mealType|capitalize }}</span></td>
        <td><span class="badge bg-secondary">{{ recipe.difficulty|capitalize }}</span></td>
        <td>{{ recipe.createdAt|date('M d, Y') }}</td>
        <td>
          <a href="{{ path('app_recipe_show', {id: recipe.id}) }}" class="btn btn-sm btn-outline-dark">View</a>
          <a href="{{ path('app_admin_recipe_edit', {id: recipe.id}) }}" class="btn btn-sm btn-outline-primary">Edit</a>
          <form action="{{ path('app_admin_recipe_delete', {id: recipe.id}) }}" method="POST" class="d-inline"
                onsubmit="return confirm('Delete this recipe?')">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ recipe.id) }}">
            <button class="btn btn-sm btn-outline-danger">Delete</button>
          </form>
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% endif %}
{% endblock %}