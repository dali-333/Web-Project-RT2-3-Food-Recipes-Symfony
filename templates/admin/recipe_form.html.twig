{% extends 'base.html.twig' %}
{% block title %}{{ edit ? 'Edit' : 'New' }} Recipe{% endblock %}

{% block body %}
<div class="row justify-content-center">
  <div class="col-md-8">
    <div class="card shadow">
      <div class="card-body p-4">
        <h2 class="mb-4">{{ edit ? '✏️ Edit Recipe' : '🍳 New Recipe' }}</h2>

        {{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}
        <div class="row g-3">
          <div class="col-12">
            <label class="form-label fw-bold">Title</label>
            {{ form_widget(form.title) }}
          </div>
          <div class="col-12">
            <label class="form-label fw-bold">Description</label>
            {{ form_widget(form.description) }}
          </div>
          <div class="col-md-4">
            <label class="form-label fw-bold">Cuisine</label>
            {{ form_widget(form.cuisine) }}
          </div>
          <div class="col-md-4">
            <label class="form-label fw-bold">Meal Type</label>
            {{ form_widget(form.mealType) }}
          </div>
          <div class="col-md-4">
            <label class="form-label fw-bold">Difficulty</label>
            {{ form_widget(form.difficulty) }}
          </div>
          <div class="col-md-4">
            <label class="form-label fw-bold">Prep Time (min)</label>
            {{ form_widget(form.prepTime) }}
          </div>
          <div class="col-md-4">
            <label class="form-label fw-bold">Cook Time (min)</label>
            {{ form_widget(form.cookTime) }}
          </div>
          <div class="col-md-4">
            <label class="form-label fw-bold">Servings</label>
            {{ form_widget(form.servings) }}
          </div>
          <div class="col-12">
            <label class="form-label fw-bold">Instructions</label>
            {{ form_widget(form.instructions) }}
            <small class="text-muted">Write each step on a new line.</small>
          </div>
          <div class="col-12">
            <label class="form-label fw-bold">Recipe Image</label>
            {{ form_widget(form.imageFile) }}
            {% if edit and recipe.imageFilename %}
              <div class="mt-2">
                <img src="/uploads/recipes/{{ recipe.imageFilename }}" height="80" class="rounded">
                <small class="text-muted ms-2">Current image</small>
              </div>
            {% endif %}
          </div>
          <div class="col-12">
            <label class="form-label fw-bold">Ingredients</label>
            <div id="ingredients-wrapper">
                {% for ingredientForm in form.recipeIngredients %}
                <div class="ingredient-row row g-2 mb-2">
                    <div class="col-5">
                        {{ form_widget(ingredientForm.ingredientName) }}
                    </div>
                    <div class="col-5">
                        {{ form_widget(ingredientForm.quantity) }}
                    </div>
                    <div class="col-2">
                        <button type="button" class="btn btn-outline-danger w-100 remove-ingredient">✕</button>
                    </div>
                </div>
                {% endfor %}
            </div>
            <button type="button" id="add-ingredient" class="btn btn-outline-secondary btn-sm mt-2">+ Add Ingredient</button>
        </div>
          <div class="col-12 d-flex gap-2">
            <button type="submit" class="btn btn-warning fw-bold">
              {{ edit ? 'Save Changes' : 'Publish Recipe' }}
            </button>
            <a href="{{ path('app_admin') }}" class="btn btn-outline-secondary">Cancel</a>
          </div>
        </div>
        {{ form_end(form) }}
      </div>
    </div>
  </div>
</div>
{% block javascripts %}
<script>
const wrapper = document.getElementById('ingredients-wrapper');
let index = wrapper.querySelectorAll('.ingredient-row').length;

const prototype = {{ form.recipeIngredients.vars.prototype|json_encode|raw }};

document.getElementById('add-ingredient').addEventListener('click', function () {
    const proto = `
        <div class="ingredient-row row g-2 mb-2">
            <div class="col-5">
                <input type="text" name="recipe[recipeIngredients][${index}][ingredientName]"
                       class="form-control" placeholder="e.g. Tomato">
            </div>
            <div class="col-5">
                <input type="text" name="recipe[recipeIngredients][${index}][quantity]"
                       class="form-control" placeholder="e.g. 2 cups">
            </div>
            <div class="col-2">
                <button type="button" class="btn btn-outline-danger w-100 remove-ingredient">✕</button>
            </div>
        </div>`;
    wrapper.insertAdjacentHTML('beforeend', proto);
    index++;
});

wrapper.addEventListener('click', function (e) {
    if (e.target.classList.contains('remove-ingredient')) {
        e.target.closest('.ingredient-row').remove();
    }
});
</script>
{% endblock %}
{% endblock %}