{% extends 'base.html.twig' %}
{% block title %}Recipe Suggester{% endblock %}

{% block body %}
<div class="text-center mb-5">
    <h1 class="display-5">🧠 What can I cook?</h1>
    <p class="text-muted">Enter the ingredients you have and we'll suggest matching recipes.</p>

    <form method="GET" action="{{ path('app_suggest') }}" class="row justify-content-center g-2 mt-3">
        <div class="col-md-6">
            <input type="text"
                   name="ingredients"
                   class="form-control form-control-lg"
                   placeholder="e.g. tomato, egg, cheese"
                   value="{{ input }}"
                   id="ingredient-input">
            <small class="text-muted">Separate ingredients with commas</small>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-warning btn-lg">Suggest Recipes 🍳</button>
        </div>
    </form>

    {# Tag display #}
    <div id="tag-container" class="mt-3 d-flex flex-wrap justify-content-center gap-2"></div>
</div>

{% if input %}
    {% if suggestions is empty %}
        <div class="text-center py-4">
            <p class="fs-5 text-muted">😕 No recipes found with those ingredients.</p>
            <p class="text-muted">Try fewer or different ingredients.</p>
        </div>
    {% else %}
        <h4 class="mb-3">Found {{ suggestions|length }} matching recipe{{ suggestions|length > 1 ? 's' : '' }}</h4>
        <div class="row row-cols-1 row-cols-md-3 g-4">
            {% for item in suggestions %}
            {% set recipe = item.recipe %}
            <div class="col">
                <div class="card h-100 shadow-sm">
                    {% if recipe.imageFilename %}
                        <img src="{{ asset('uploads/recipes/' ~ recipe.imageFilename) }}"
                             class="card-img-top" style="height:180px;object-fit:cover" alt="{{ recipe.title }}">
                    {% else %}
                        <div class="bg-light d-flex align-items-center justify-content-center text-muted"
                             style="height:180px;font-size:3rem">🍽️</div>
                    {% endif %}
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="badge bg-warning text-dark">{{ recipe.mealType|capitalize }}</span>
                            <span class="badge bg-success">{{ item.matchPercent }}% match</span>
                        </div>
                        <h5 class="card-title">{{ recipe.title }}</h5>
                        <p class="text-muted small">
                            ✅ {{ item.matchCount }} of {{ item.totalIngredients }} ingredients matched
                        </p>

                        {# Show which ingredients matched #}
                        <div class="d-flex flex-wrap gap-1">
                        {% for ri in recipe.recipeIngredients %}
                            <span class="badge bg-light text-dark border">{{ ri.ingredient.name }}</span>
                        {% endfor %}
                        </div>
                    </div>
                    <div class="card-footer">
                        <a href="{{ path('app_recipe_show', {id: recipe.id}) }}" class="btn btn-warning btn-sm w-100">
                            View Full Recipe →
                        </a>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    {% endif %}
{% endif %}
{% endblock %}

{% block javascripts %}
<script>
const inputField = document.getElementById('ingredient-input');
const tagContainer = document.getElementById('tag-container');

function renderTags() {
    const value = inputField.value;
    const parts = value.split(',').map(s => s.trim()).filter(Boolean);
    tagContainer.innerHTML = parts.map(p =>
        `<span class="badge bg-warning text-dark fs-6">🧂 ${p}</span>`
    ).join('');
}

inputField.addEventListener('input', renderTags);
renderTags();
</script>
{% endblock %}