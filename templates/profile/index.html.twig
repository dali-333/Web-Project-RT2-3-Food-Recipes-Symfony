{% extends 'base.html.twig' %}
{% block title %}My Profile{% endblock %}

{% block body %}
<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card shadow">
      <div class="card-body p-4 text-center">
        <div class="display-1 mb-3">👤</div>
        <h2>{{ app.user.username }}</h2>
        <p class="text-muted">{{ app.user.email }}</p>
        <span class="badge {{ 'ROLE_ADMIN' in app.user.roles ? 'bg-danger' : 'bg-success' }} fs-6">
          {{ 'ROLE_ADMIN' in app.user.roles ? '👨‍🍳 Chef (Admin)' : '🧑 Member' }}
        </span>
        <hr>
        <p class="text-muted">Member since {{ app.user.createdAt|date('F Y') }}</p>
        <a href="{{ path('app_favorites') }}" class="btn btn-outline-danger me-2">❤️ My Favorites</a>
        <a href="{{ path('app_logout') }}" class="btn btn-outline-secondary">Logout</a>
      </div>
    </div>
  </div>
</div>
{% endblock %}