{% extends 'base.html.twig' %}
{% block title %}My Profile{% endblock %}

{% block body %}
<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card shadow">
      <div class="card-body p-4 text-center">
        <div class="display-1 mb-3">👤</div>
        <h2>{{ app.user.username }}</h2>
        <p class="text-muted">{{ app.user.email }}</p>
        <span class="badge {{ 'ROLE_ADMIN' in app.user.roles ? 'bg-danger' : 'bg-success' }} fs-6">
          {{ 'ROLE_ADMIN' in app.user.roles ? '👨‍🍳 Chef (Admin)' : '🧑 Member' }}
        </span>
        <hr>
        <p class="text-muted">Member since {{ app.user.createdAt|date('F Y') }}</p>

        <div class="d-flex flex-wrap justify-content-center gap-2">
          <a href="{{ path('app_favorites') }}" class="btn btn-outline-danger">❤️ My Favorites</a>
          <a href="{{ path('app_profile_edit') }}" class="btn btn-outline-primary">✏️ Edit Profile</a>
        </div>

        <hr>

        {# Delete account #}
        <button class="btn btn-sm btn-link text-danger" data-bs-toggle="collapse" data-bs-target="#deleteSection">
          Delete my account
        </button>
        <div class="collapse mt-3" id="deleteSection">
          <div class="alert alert-danger text-start">
            <strong>⚠️ This is permanent.</strong> Your account and all data will be deleted.
            <form action="{{ path('app_profile_delete') }}" method="POST" class="mt-2">
              <input type="hidden" name="_token" value="{{ csrf_token('delete-account') }}">
              <button class="btn btn-danger btn-sm w-100">Yes, delete my account</button>
            </form>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>
{% endblock %}