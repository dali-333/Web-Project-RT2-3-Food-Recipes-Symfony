{% extends 'base.html.twig' %}
{% block title %}Edit Profile{% endblock %}

{% block body %}
<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card shadow">
      <div class="card-body p-4">
        <h2 class="mb-4">✏️ Edit Profile</h2>

        {{ form_start(form) }}
        <div class="mb-3">
          <label class="form-label fw-bold">Username</label>
          {{ form_widget(form.username) }}
          {{ form_errors(form.username) }}
        </div>
        <div class="mb-3">
          <label class="form-label fw-bold">Email</label>
          {{ form_widget(form.email) }}
          {{ form_errors(form.email) }}
        </div>
        <hr>
        <p class="text-muted small">Leave password fields empty to keep your current password.</p>
        <div class="mb-3">
          <label class="form-label fw-bold">New Password</label>
          {{ form_widget(form.newPassword.first) }}
          {{ form_errors(form.newPassword.first) }}
        </div>
        <div class="mb-3">
          <label class="form-label fw-bold">Confirm New Password</label>
          {{ form_widget(form.newPassword.second) }}
          {{ form_errors(form.newPassword.second) }}
        </div>
        <div class="d-flex gap-2">
          <button type="submit" class="btn btn-warning fw-bold">Save Changes</button>
          <a href="{{ path('app_profile') }}" class="btn btn-outline-secondary">Cancel</a>
        </div>
        {{ form_end(form) }}

      </div>
    </div>
  </div>
</div>
{% endblock %}