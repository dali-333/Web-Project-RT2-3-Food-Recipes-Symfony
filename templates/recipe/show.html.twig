{% extends 'base.html.twig' %}
{% block title %}{{ recipe.title }}{% endblock %}

{% block body %}
<div class="row">
  <div class="col-md-8">
    <h1>{{ recipe.title }}</h1>
    <div class="mb-2">
      <span class="badge bg-warning text-dark fs-6">{{ recipe.mealType|capitalize }}</span>
      <span class="badge bg-secondary fs-6">{{ recipe.difficulty|capitalize }}</span>
      <span class="badge bg-info text-dark fs-6">🌍 {{ recipe.cuisine.name }}</span>
    </div>
    <p class="lead">{{ recipe.description }}</p>

    <div class="row text-center my-3">
      <div class="col"><strong>⏱ Prep</strong><br>{{ recipe.prepTime }} min</div>
      <div class="col"><strong>🔥 Cook</strong><br>{{ recipe.cookTime }} min</div>
      <div class="col"><strong>👤 Serves</strong><br>{{ recipe.servings }}</div>
    </div>

    <h4>🧂 Ingredients</h4>
    {% if recipe.recipeIngredients is empty %}
        <p class="text-muted">No ingredients listed.</p>
    {% else %}
    <ul class="list-group list-group-flush mb-3">
        {% for ri in recipe.recipeIngredients %}
        <li class="list-group-item d-flex justify-content-between">
            <span>{{ ri.ingredient.name }}</span>
            <span class="text-muted">{{ ri.quantity }}</span>
        </li>
        {% endfor %}
    </ul>
    {% endif %}

    <h4 class="mt-4">📋 Instructions</h4>
    <p>{{ recipe.instructions|nl2br }}</p>
  </div>

  <div class="col-md-4">
    {% if recipe.imageFilename %}
      <img src="/uploads/recipes/{{ recipe.imageFilename }}" class="img-fluid rounded shadow">
    {% endif %}

    <div class="mt-3">
      <p class="text-muted">By <strong>{{ recipe.author.username }}</strong></p>
      <p class="text-muted">Posted: {{ recipe.createdAt|date('M d, Y') }}</p>
    </div>

    {% if is_granted('ROLE_USER') %}
    <form action="{{ path('app_favorite_toggle', {id: recipe.id}) }}" method="POST">
      <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ recipe.id) }}">
      <button class="btn btn-{{ isFavorited ? 'danger' : 'outline-danger' }} w-100 mt-2">
        {{ isFavorited ? '❤️ Remove from Favorites' : '🤍 Add to Favorites' }}
      </button>
    </form>
    {% endif %}
  </div>
</div>

<a href="{{ path('app_recipes') }}" class="btn btn-outline-secondary mt-4">← Back to Recipes</a>
{% endblock %}